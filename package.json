{
  "name": "proyecto-final-is",
  "private": true,
  "scripts": {
    "install:backend": "cd backend && python -m pip install -r requirements.txt",
    "install:frontend": "pnpm --dir frontend install",
    "backend:dev": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "frontend:dev": "pnpm --dir frontend dev -- --host 0.0.0.0",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  }
}
